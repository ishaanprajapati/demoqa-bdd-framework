{
  "name": "demoqa-bdd",
  "version": "1.0.0",
  "scripts": {
    "pretest": "node src/initialize.js",
    "test": "npx cucumber-js",
    "test:bookstore": "cross-env ENV=demoqa BROWSER=chrome npx cucumber-js --tags \"@BookStoreApplication\"",
    "test:ui": "cross-env ENV=demoqa BROWSER=chrome npx cucumber-js --tags \"@UI\"",
    "test:api": "cross-env ENV=demoqa npx cucumber-js --tags \"@CreateGetUpdateUser\"",
    "test:headless": "cross-env ENV=demoqa BROWSER=chrome HEADLESS=true npx cucumber-js",
    "report": "node generate-report.js"
  },
  "dependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.44.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.44.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "multiple-cucumber-html-reporter": "^3.10.0"
  }
}
